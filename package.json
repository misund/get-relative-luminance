{
  "name": "get-relative-luminance",
  "version": "2.0.0",
  "description": "Get relative luminance from a color string.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint --max-warnings=0 src/**/*.ts",
    "mocha": "mocha",
    "test": "yarn lint && yarn mocha",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test",
    "preversion": "yarn test",
    "release": "np"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misund/get-relative-luminance.git"
  },
  "keywords": [
    "luminance",
    "relative",
    "luminance",
    "wcag",
    "contrast",
    "ratio"
  ],
  "author": "Just Thomas Hiorth Misund",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/misund/get-relative-luminance/issues"
  },
  "homepage": "https://github.com/misund/get-relative-luminance#readme",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "10.0.1",
    "@types/mocha": "10.0.10",
    "@types/node": "25.2.0",
    "@types/parse-color": "1.0.3",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "9.39.2",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "mocha": "11.7.5",
    "np": "11.0.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "parse-color": "1.0.0"
  }
}
